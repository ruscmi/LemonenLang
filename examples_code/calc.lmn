n1 = lmtod(lmout("first number: ")); n2 = lmtod(lmout("second number: ")); op = lmout("op: ");
if(n1 != 0 && n2 != 0) {
    if(op == "+") {
        lmuck(n1+n2)
    }
    else if(op == "-") {
        lmuck(n1-n2)
    }
    else if(op == "/") {
        lmuck(n1/n2)
    }
    else if(op == "*") {
        lmuck(n1*n2)
    }
    else {
        lmuck("E: do es not parsing expression")
    }
}else {
    lmuck("E: do es not parsing two zeros")
}
